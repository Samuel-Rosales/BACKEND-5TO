{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/src/server/server.server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/exchange-rate",
      "schedule": "30 8 * * *"
    }
  ]
}