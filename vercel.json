{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/dist/api/index" }
  ],
  "crons": [
    {
      "path": "/api/cron/exchange-rate",
      "schedule": "30 8 * * *"
    }
  ]
}