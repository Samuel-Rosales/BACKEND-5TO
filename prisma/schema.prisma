// Configuración inicial del generador y la fuente de datos
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
}

// ==========================================
// 🛡️ MÓDULO DE IDENTIDAD Y ACCESO
// ==========================================

model Role {
  id      Int    @id @default(autoincrement())
  name    String @unique
  code    String @unique
  active  Boolean @default(true)

  users User[]
}

model User {
  id       Int      @id @default(autoincrement())
  ci       String   @unique
  name     String
  password String
  roleId   Int
  active   Boolean  @default(true)

  role     Role     @relation(fields: [roleId], references: [id])
  doctor   Doctor?
  patient  Patient?
  stockMovements StockMovement[]
  purchases      Purchase[]
}

// ==========================================
// 🩺 MÓDULO CLÍNICO Y PACIENTES
// ==========================================

model Patient {
  id              Int            @id @default(autoincrement())
  userId          Int?           @unique
  user            User?          @relation(fields: [userId], references: [id])
  tipo_sangre     String?        @db.Text
  medical_history String?        @db.Text
  active          Boolean        @default(true)
  
  appointments    Appoinment[]
  consultations   Consultation[]
}

model Doctor {
  id                Int                     @id @default(autoincrement())
  userId            Int                     @unique
  user              User                    @relation(fields: [userId], references: [id])
  specialtyId       Int
  specialty         MedicalSpecialty        @relation(fields: [specialtyId], references: [id])
  availabilities    DoctorAvailability[]
  overrides         DoctorScheduleOverride[]
  appointments      Appoinment[]
  consultations     Consultation[]
}

model MedicalSpecialty {
  id                    Int      @id @default(autoincrement())
  name                  String
  consultation_price    Decimal  @db.Decimal(12, 2)
  commission_percentage Decimal  @db.Decimal(5, 2) // Ej: 30.00 para la clínica
  doctors               Doctor[]
}

// ==========================================
// 📅 MÓDULO DE AGENDA Y DISPONIBILIDAD
// ==========================================

model Appoinment {
  id                 Int               @id @default(autoincrement())
  doctorId           Int
  doctor             Doctor            @relation(fields: [doctorId], references: [id])
  patientId          Int
  patient            Patient           @relation(fields: [patientId], references: [id])
  statusId           Int
  status             StatusAppointment @relation(fields: [statusId], references: [id])
  typeId             Int
  type               AppointmentType   @relation(fields: [typeId], references: [id])
  reson_visit        String?           @db.Text
  price              Decimal           @db.Decimal(12, 2)
  start_datetime     DateTime
  end_datetime       DateTime
  consultation       Consultation?
}

model StatusAppointment {
  id           Int          @id @default(autoincrement())
  name         String
  color_hex    String?
  appointments Appoinment[]
}

model AppointmentType {
  id           Int          @id @default(autoincrement())
  name         String
  appointments Appoinment[]
}

model DoctorAvailability {
  id            Int    @id @default(autoincrement())
  doctorId      Int
  doctor        Doctor @relation(fields: [doctorId], references: [id])
  day_of_week   Int    // 0-6
  start_time    DateTime @db.Time
  end_time      DateTime @db.Time
  slot_duration Int    // Minutos
}

model DoctorScheduleOverride {
  id            Int      @id @default(autoincrement())
  doctorId      Int
  doctor        Doctor   @relation(fields: [doctorId], references: [id])
  specific_date DateTime
  is_working    Boolean  @default(true)
  start_time    DateTime? @db.Time
  end_time      DateTime? @db.Time
  reason        String?
}

// ==========================================
// 📝 MÓDULO DE CONSULTA Y RECETAS
// ==========================================

model Consultation {
  id             Int                 @id @default(autoincrement())
  appointmentId  Int?                @unique
  appointment    Appoinment?         @relation(fields: [appointmentId], references: [id])
  patientId      Int
  patient        Patient             @relation(fields: [patientId], references: [id])
  doctorId       Int
  doctor         Doctor              @relation(fields: [doctorId], references: [id])
  date           DateTime            @default(now()) @db.Date
  started_at     DateTime
  finished_at    DateTime
  symptoms       String?             @db.Text
  diagnosis      String?             @db.Text
  physical_exam  String?             @db.Text
  supplies       SupplyConsultation[]
  prescriptions  Prescription[]
  invoice        Invoice?
}

model Prescription {
  id              Int          @id @default(autoincrement())
  consultationId  Int
  consultation    Consultation @relation(fields: [consultationId], references: [id])
  productId       Int?
  product         Product?     @relation(fields: [productId], references: [id])
  medication_name String?
  dosage          String?
  frequency       String?
  duration        String?
  instructions    String?      @db.Text
}

// ==========================================
// 💰 MÓDULO FINANCIERO (FACTURACIÓN E IGTF)
// ==========================================

model Invoice {
  id              Int              @id @default(autoincrement())
  consultationId  Int              @unique
  consultation    Consultation     @relation(fields: [consultationId], references: [id])
  exchangeRateId  Int
  exchangeRate    ExchangeRate     @relation(fields: [exchangeRateId], references: [id])
  total_usd       Decimal          @db.Decimal(12, 2)
  total_bs        Decimal          @db.Decimal(12, 2)
  statusId        Int
  status          StatusInvoice    @relation(fields: [statusId], references: [id])
  details         InvoiceDetail[]
  payments        InvoicePayment[]
}

model StatusInvoice {
  id       Int       @id @default(autoincrement())
  name     String
  color_hex String?
  invoices Invoice[]
}

model InvoiceDetail {
  id               Int     @id @default(autoincrement())
  invoiceId        Int
  invoice          Invoice @relation(fields: [invoiceId], references: [id])
  productId        Int?
  product          Product? @relation(fields: [productId], references: [id])
  description      String
  quantity         Int
  unit_price       Decimal @db.Decimal(12, 2)
  taxId            Int
  tax              Tax     @relation(fields: [taxId], references: [id])
  is_commissionable Boolean @default(false)
}

model InvoicePayment {
  id               Int           @id @default(autoincrement())
  invoiceId        Int
  invoice          Invoice       @relation(fields: [invoiceId], references: [id])
  paymentMethodId  Int
  paymentMethod    PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  currencyId       Int
  amount_paid      Decimal       @db.Decimal(12, 2)
  igtf_amount      Decimal       @db.Decimal(12, 2) @default(0)
  exchangeRateId   Int
  exchangeRate     ExchangeRate  @relation(fields: [exchangeRateId], references: [id])
}

model ExchangeRate {
  id              Int              @id @default(autoincrement())
  rate            Decimal          @db.Decimal(12, 4)
  createdAt       DateTime         @default(now())
  is_active       Boolean          @default(true)
  invoices        Invoice[]
  invoicePayments InvoicePayment[]
  expenses        InvoiceExpense[]
  expensePayments ExpensePayment[]
  purchases       Purchase[]
}

// ==========================================
// 📦 MÓDULO DE INVENTARIO Y COMPRAS
// ==========================================

model Product {
  id                 Int                  @id @default(autoincrement())
  name               String
  sku                String?              @unique
  description        String?
  cost_price         Decimal              @db.Decimal(12, 2)
  min_stock          Int                  @default(0)
  is_active          Boolean              @default(true)
  categoryId         Int
  category           Category             @relation(fields: [categoryId], references: [id])
  unitId             Int
  unit               MeasurementUnit      @relation(fields: [unitId], references: [id])
  presentations      ProductPresentation[]
  stockLots          StockLot[]
  stockMovements     StockMovement[]
  supplyConsultations SupplyConsultation[]
  invoiceDetails     InvoiceDetail[]
  purchaseItems      PurchaseItem[]
  prescriptions      Prescription[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  products Product[]
}

model MeasurementUnit {
  id       Int       @id @default(autoincrement())
  name     String
  symbol   String
  products Product[]
}

model SupplyConsultation {
  id             Int          @id @default(autoincrement())
  productId      Int
  product        Product      @relation(fields: [productId], references: [id])
  consultationId Int
  consultation    Consultation @relation(fields: [consultationId], references: [id])
  quantity       Decimal      @db.Decimal(10, 2)
}

// ==========================================
// 🏢 MÓDULO DE GASTOS OPERATIVOS (OPEX)
// ==========================================

model ExpenseCategory {
  id       Int              @id @default(autoincrement())
  name     String
  expenses InvoiceExpense[]
}

model InvoiceExpense {
  id              Int              @id @default(autoincrement())
  categoryId      Int
  category        ExpenseCategory  @relation(fields: [categoryId], references: [id])
  supplierId      Int
  supplier        Supplier         @relation(fields: [supplierId], references: [id])
  exchangeRateId  Int
  exchangeRate    ExchangeRate     @relation(fields: [exchangeRateId], references: [id])
  total_amount    Decimal          @db.Decimal(12, 2)
  date_at         DateTime         @default(now())
  payments        ExpensePayment[]
}

model ExpensePayment {
  id               Int            @id @default(autoincrement())
  invoiceExpenseId Int
  invoiceExpense   InvoiceExpense @relation(fields: [invoiceExpenseId], references: [id])
  paymentMethodId  Int
  paymentMethod    PaymentMethod  @relation(fields: [paymentMethodId], references: [id])
  amount           Decimal        @db.Decimal(12, 2)
  igtf_amount      Decimal        @db.Decimal(12, 2) @default(0)
  exchangeRateId   Int
  exchangeRate     ExchangeRate   @relation(fields: [exchangeRateId], references: [id])
  date_at          DateTime       @default(now())
}

// ==========================================
// 🛠️ TABLAS MAESTRAS Y SOPORTE (Tax, Supplier, etc.)
// ==========================================

model Tax {
  id             Int             @id @default(autoincrement())
  name           String
  rate           Decimal         @db.Decimal(5, 2)
  isActive       Boolean         @default(true)
  invoiceDetails InvoiceDetail[]
}

model PaymentMethod {
  id              Int              @id @default(autoincrement())
  name            String
  type            String           // Cash, Transfer, etc.
  currency        String           // USD, VES
  invoicePayments InvoicePayment[]
  expensePayments ExpensePayment[]
  purchasePayments PurchasePayment[]
}

model Supplier {
  id        Int              @id @default(autoincrement())
  name      String
  contact   String?
  phone     String?
  expenses  InvoiceExpense[]
  purchases Purchase[]
}

// --- Resto de tablas (StockLot, StockMovement, Purchase, etc.) simplificadas ---
// (Deben seguir el mismo patrón de relaciones que las anteriores)

model StockLot {
  id              Int             @id @default(autoincrement())
  quantity        Int
  productId       Int
  product         Product         @relation(fields: [productId], references: [id])
  expiration_date DateTime?
  lot_cost        Decimal         @db.Decimal(12, 2)
  createdAt       DateTime        @default(now())
  movements       StockMovement[]
}

model StockMovement {
  id         Int      @id @default(autoincrement())
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])
  stockLotId Int
  stockLot   StockLot @relation(fields: [stockLotId], references: [id])
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  type       String   // IN, OUT
  quantity   Int
  reason     String?
  date       DateTime @default(now())
}

model Purchase {
  id             Int            @id @default(autoincrement())
  supplierId     Int
  supplier       Supplier       @relation(fields: [supplierId], references: [id])
  userId         Int
  user           User           @relation(fields: [userId], references: [id])
  total_cost     Decimal        @db.Decimal(12, 2)
  exchangeRateId Int
  exchangeRate   ExchangeRate   @relation(fields: [exchangeRateId], references: [id])
  date           DateTime       @default(now())
  items          PurchaseItem[]
  payments       PurchasePayment[]
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  unit_cost  Decimal  @db.Decimal(12, 2)
}

model PurchasePayment {
  id              Int           @id @default(autoincrement())
  purchaseId      Int
  purchase        Purchase      @relation(fields: [purchaseId], references: [id])
  paymentMethodId Int
  paymentMethod    PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  amount          Decimal       @db.Decimal(12, 2)
}

model ProductPresentation {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  name      String
  factor    Decimal @db.Decimal(10, 2)
  price     Decimal @db.Decimal(12, 2)
}